# ── Azure OpenAI (chat) ──────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment-name

# ── Azure OpenAI (embeddings) — used to index the repo into ChromaDB ─────────
# Deploy an embeddings model (e.g. text-embedding-3-small) in your Azure resource
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name

# ── Embeddings provider ──────────────────────────────────────────────────────
# "azure" (default) uses the Azure embeddings deployment above.
# "huggingface" runs a local sentence-transformers model (free, no API calls).
EMBEDDING_PROVIDER=azure
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Repo deep-scan tuning ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./.chroma
MAX_FILE_SIZE_KB=512          # skip files larger than this
RETRIEVAL_TOP_K=12            # chunks each agent pulls per query
SCAN_WORKSPACE_DIR=./.scan_workspace

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./code_review_bot.db

# ── GitHub OAuth (login + commit/push/PR to remote repos) ────────────────────
# Optional: only needed to apply, commit and push fixes to remote GitHub repos.
# Register an OAuth App at https://github.com/settings/developers with:
#   Homepage URL:               http://localhost:5173
#   Authorization callback URL: http://localhost:5173/api/auth/github/callback
# Then paste the client id/secret below. Leave blank to disable the login button
# (local-path scans can still be committed without GitHub sign-in).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must exactly match the callback URL registered on the OAuth App above.
GITHUB_OAUTH_CALLBACK=http://localhost:5173/api/auth/github/callback
# OAuth scope: "repo" covers private repos + opening PRs; use "public_repo" to
# limit access to public repositories only.
GITHUB_OAUTH_SCOPE=repo
# Where the browser is sent after a successful login (your frontend origin).
FRONTEND_URL=http://localhost:5173
# Name of the HttpOnly session cookie that references the server-side token.
SESSION_COOKIE=crb_session

# ── Pre-commit verification (optional) ───────────────────────────────────────
# If set, this command runs in the repo root after fixes are applied but BEFORE
# committing. A non-zero exit aborts the commit and reverts the changes, so
# breaking code is never committed or pushed. Example: "pytest -q" or "npm test".
CODE_REVIEW_VERIFY_CMD=

